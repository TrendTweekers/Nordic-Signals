# Required — without this, the forms return 500
RESEND_API_KEY=re_...

# Required — verified sender (or onboarding@resend.dev for testing)
DIGEST_FROM=onboarding@resend.dev

# Required — your inbox; you get an email for every signup
NOTIFY_TO=you@yourdomain.com

# Optional — separate inbox for portfolio waitlist signups
PORTFOLIO_NOTIFY_TO=

# Optional — Resend audience IDs. If set, contacts are auto-pushed there.
# If unset, signups still work; you'll just collect them via NOTIFY_TO emails.
RESEND_AUDIENCE_ID=
RESEND_PORTFOLIO_AUDIENCE_ID=
